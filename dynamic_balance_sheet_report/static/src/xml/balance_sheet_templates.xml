<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="dynamic_balance_sheet_report.BalanceSheetReportTemplate" owl="1">
        <div class="o_balance_sheet_report" style="height: 100%; display: flex; flex-direction: column; background: white;">
            <style>
                .o_balance_sheet_report { font-family: 'Inter', 'Segoe UI', sans-serif; color: #374151; }
                .o_content_header { padding: 16px 24px; background: white; border-bottom: 1px solid #e5e7eb; }
                .o_content_body { flex: 1; overflow-y: auto; padding: 24px; }
                .o_filter_panel { 
                    background: #f9fafb; 
                    border: 1px solid #f3f4f6; 
                    border-radius: 8px; 
                    margin-bottom: 30px;
                }
                .o_report_container {
                    border: 1px solid #e5e7eb;
                    border-radius: 4px;
                    overflow: hidden;
                    background: white;
                }
                .journal-tag {
                    display: inline-flex;
                    align-items: center;
                    gap: 4px;
                    background: #e0e7ff;
                    color: #3730a3;
                    border-radius: 999px;
                    padding: 2px 10px 2px 10px;
                    font-size: 12px;
                    font-weight: 500;
                    cursor: default;
                }
                .journal-tag .remove-btn {
                    cursor: pointer;
                    font-size: 14px;
                    line-height: 1;
                    color: #6366f1;
                    margin-left: 2px;
                    border: none;
                    background: none;
                    padding: 0;
                }
                .journal-tag .remove-btn:hover { color: #dc2626; }
                .journal-dropdown-item { cursor: pointer; user-select: none; }
                .journal-dropdown-item:hover { background: #f3f4f6; }
                .export-modal-backdrop {
                    position: fixed;
                    inset: 0;
                    background: rgba(0,0,0,0.35);
                    z-index: 1055;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }
                .export-modal {
                    background: white;
                    border-radius: 12px;
                    padding: 28px 32px;
                    width: 420px;
                    box-shadow: 0 20px 60px rgba(0,0,0,0.18);
                }
                .export-option-card {
                    border: 2px solid #e5e7eb;
                    border-radius: 10px;
                    padding: 16px 20px;
                    cursor: pointer;
                    transition: all 0.15s;
                    display: flex;
                    align-items: flex-start;
                    gap: 14px;
                }
                .export-option-card:hover {
                    border-color: #6366f1;
                    background: #f5f3ff;
                }
                .export-option-icon {
                    font-size: 22px;
                    margin-top: 2px;
                    flex-shrink: 0;
                }
                .export-option-title {
                    font-weight: 600;
                    font-size: 14px;
                    color: #111827;
                    margin-bottom: 3px;
                }
                .export-option-desc {
                    font-size: 12px;
                    color: #6b7280;
                    line-height: 1.4;
                }
            </style>
            <div class="o_content_header">
                <h1 class="o_content_title" style="font-size: 20px; font-weight: 600; margin: 0;">Balance Sheet Report</h1>
            </div>
            <div class="o_content_body">
                <div class="o_filter_panel p-4">
                    <div class="row g-3 align-items-end">
                        <!-- Date Filter Dropdown -->
                        <div class="col-md-auto">
                            <label class="form-label small fw-bold d-block">DATE</label>
                            <div class="dropdown">
                                <button class="btn btn-outline-secondary btn-sm dropdown-toggle d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="oi oi-calendar"/>
                                    <span><t t-esc="formattedDateFrom"/> – <t t-esc="formattedDate"/></span>
                                </button>
                                <ul class="dropdown-menu shadow-sm p-2" style="min-width: 280px;">
                                    <li><a class="dropdown-item d-flex justify-content-between align-items-center py-2" href="#" t-on-click="() => this.applyDatePreset('today')">
                                        Today <i t-if="state.date_filter_type === 'today'" class="oi oi-check text-primary"/>
                                    </a></li>
                                    <li><a class="dropdown-item d-flex justify-content-between align-items-center py-2" href="#" t-on-click="() => this.applyDatePreset('end_month')">
                                        End of Month <i t-if="state.date_filter_type === 'end_month'" class="oi oi-check text-primary"/>
                                    </a></li>
                                    <li><a class="dropdown-item d-flex justify-content-between align-items-center py-2" href="#" t-on-click="() => this.applyDatePreset('end_quarter')">
                                        End of Quarter <i t-if="state.date_filter_type === 'end_quarter'" class="oi oi-check text-primary"/>
                                    </a></li>
                                    <li><a class="dropdown-item d-flex justify-content-between align-items-center py-2" href="#" t-on-click="() => this.applyDatePreset('end_year')">
                                        End of Year <i t-if="state.date_filter_type === 'end_year'" class="oi oi-check text-primary"/>
                                    </a></li>
                                    <li><hr class="dropdown-divider"/></li>
                                    <li class="px-3 py-2">
                                        <label class="form-label small fw-bold mb-1">Specific Date Range</label>
                                        <div class="d-flex flex-column gap-2">
                                            <div>
                                                <label class="form-label small text-muted mb-1">Start Date</label>
                                                <input type="date" t-att-value="state.date_from" class="form-control form-control-sm" t-on-change="onDateFromChange"/>
                                            </div>
                                            <div>
                                                <label class="form-label small text-muted mb-1">End Date</label>
                                                <input type="date" t-att-value="state.date" class="form-control form-control-sm" t-on-change="onDateChange"/>
                                            </div>
                                        </div>
                                    </li>
                                </ul>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-bold">TARGET MOVES</label>
                            <select class="form-select form-select-sm" t-att-value="state.target_move" t-on-change="onTargetMoveChange">
                                <option value="posted">All Posted Entries</option>
                                <option value="all">All Entries</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-bold">COMPANY</label>
                            <div class="dropdown">
                                <button class="btn btn-outline-secondary btn-sm dropdown-toggle w-100 text-start" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
                                    <t t-if="state.selected_company_ids.length > 0">
                                        <t t-esc="state.selected_company_ids.length"/> Selected
                                    </t>
                                    <t t-else="">All Companies</t>
                                </button>
                                <div class="dropdown-menu shadow-sm p-2" style="min-width: 280px; max-height: 380px; overflow-y: auto;">
                                    <!-- All / Clear -->
                                    <div class="d-flex gap-2 mb-2 pb-2 border-bottom">
                                        <button class="btn btn-sm btn-outline-primary flex-fill" t-on-click.stop="selectAllCompanies">
                                            <i class="oi oi-check me-1" style="font-size: 10px;"/> All
                                        </button>
                                        <button class="btn btn-sm btn-outline-secondary flex-fill" t-on-click.stop="clearAllCompanies">
                                            <i class="oi oi-close me-1" style="font-size: 10px;"/> Clear
                                        </button>
                                    </div>
                                    <!-- Search -->
                                    <div class="mb-2 pb-2 border-bottom">
                                        <input type="text"
                                            class="form-control form-control-sm"
                                            placeholder="Search company..."
                                            t-att-value="state.company_search"
                                            t-on-input.stop="(ev) => { state.company_search = ev.target.value; }"
                                            t-on-click.stop="() => {}"/>
                                    </div>
                                    <!-- Selected chips -->
                                    <t t-if="state.selected_company_ids.length > 0">
                                        <div class="d-flex flex-wrap gap-1 mb-2 pb-2 border-bottom">
                                            <t t-foreach="selectedCompanies" t-as="company" t-key="company.id">
                                                <span class="journal-tag">
                                                    <t t-esc="company.name"/>
                                                    <button class="remove-btn" t-on-click.stop="() => this.removeCompany(company.id)" title="Remove">&#x2715;</button>
                                                </span>
                                            </t>
                                        </div>
                                    </t>
                                    <!-- Checklist -->
                                    <t t-foreach="filteredCompanies" t-as="company" t-key="company.id">
                                        <div class="journal-dropdown-item px-2 py-1 rounded d-flex align-items-center gap-2"
                                            t-on-click.stop="() => this.toggleCompany(company.id)">
                                            <input type="checkbox" class="form-check-input mt-0"
                                                t-att-checked="isCompanySelected(company.id)"
                                                style="pointer-events: none;"/>
                                            <span style="font-size: 13px; cursor: pointer;"><t t-esc="company.name"/></span>
                                        </div>
                                    </t>
                                    <t t-if="filteredCompanies.length === 0">
                                        <div class="px-2 py-2 text-muted small">No companies found</div>
                                    </t>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 d-flex align-items-end gap-2">
                            <button class="btn btn-primary btn-sm px-3" t-on-click="loadData" t-att-disabled="state.loading">
                                <t t-if="state.loading"><span class="spinner-border spinner-border-sm me-1"/> Loading...</t>
                                <t t-else="">Generate Report</t>
                            </button>
                            <button class="btn btn-outline-secondary btn-sm px-3" t-on-click="exportExcel" t-att-disabled="!hasData">Export Excel</button>
                        </div>
                    </div>

                    <!-- Journals Row -->
                    <div class="row g-2 mt-1">
                        <div class="col-12">
                            <div class="d-flex align-items-center gap-2">
                                <span class="form-label small fw-bold mb-0" style="min-width: 58px;">Journals</span>
                                <div class="dropdown">
                                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button"
                                        data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
                                        <t t-if="state.selected_journal_ids.length > 0">
                                            <t t-esc="state.selected_journal_ids.length"/> Selected
                                        </t>
                                        <t t-else="">All Journals</t>
                                    </button>
                                    <div class="dropdown-menu shadow-sm p-2" style="min-width: 300px; max-height: 420px; overflow-y: auto;">
                                        <!-- All / Clear actions -->
                                        <div class="d-flex gap-2 mb-2 pb-2 border-bottom">
                                            <button class="btn btn-sm btn-outline-primary flex-fill" t-on-click.stop="selectAllJournals">
                                                <i class="oi oi-check me-1" style="font-size: 10px;"/> All
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary flex-fill" t-on-click.stop="clearAllJournals">
                                                <i class="oi oi-close me-1" style="font-size: 10px;"/> Clear
                                            </button>
                                        </div>
                                        <!-- Search input -->
                                        <div class="mb-2 pb-2 border-bottom">
                                            <input type="text"
                                                class="form-control form-control-sm"
                                                placeholder="Search journal..."
                                                t-att-value="state.journal_search"
                                                t-on-input.stop="(ev) => { state.journal_search = ev.target.value; }"
                                                t-on-click.stop="() => {}"/>
                                        </div>
                                        <!-- Selected chips inside dropdown -->
                                        <t t-if="state.selected_journal_ids.length > 0">
                                            <div class="d-flex flex-wrap gap-1 mb-2 pb-2 border-bottom">
                                                <t t-foreach="selectedJournals" t-as="journal" t-key="journal.id">
                                                    <span class="journal-tag">
                                                        <t t-esc="journal.name"/>
                                                        <button class="remove-btn" t-on-click.stop="() => this.removeJournal(journal.id)" title="Remove">&#x2715;</button>
                                                    </span>
                                                </t>
                                            </div>
                                        </t>
                                        <!-- Journal checklist -->
                                        <t t-foreach="filteredJournals" t-as="journal" t-key="journal.id">
                                            <div class="journal-dropdown-item px-2 py-1 rounded d-flex align-items-center gap-2"
                                                t-on-click.stop="() => this.toggleJournal(journal.id)">
                                                <input type="checkbox" class="form-check-input mt-0"
                                                    t-att-checked="isJournalSelected(journal.id)"
                                                    style="pointer-events: none;"/>
                                                <span style="font-size: 13px; cursor: pointer;"><t t-esc="journal.name"/></span>
                                            </div>
                                        </t>
                                        <t t-if="filteredJournals.length === 0">
                                            <div class="px-2 py-2 text-muted small">No journals found</div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div t-if="state.has_data" class="o_report_container">
                    <BalanceSheetComponent 
                        reportData="state.report_data" 
                        expandedDetails="state.expandedDetails"
                        toggleDetail="toggleDetail"/>
                </div>
                <div t-else="" class="text-center py-5 border rounded bg-light">
                    <p class="text-muted m-0">Set filters and click "Generate Report" to view results.</p>
                </div>
            </div>

            <!-- Export Modal -->
            <t t-if="state.show_export_modal">
                <div class="export-modal-backdrop" t-on-click="cancelExport">
                    <div class="export-modal" t-on-click.stop="() => {}">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="mb-0 fw-bold" style="font-size: 16px;">Export to Excel</h5>
                            <button class="btn-close btn-sm" t-on-click="cancelExport"/>
                        </div>
                        <p class="text-muted small mb-4">Choose the export format for your Balance Sheet report.</p>
                        <div class="d-flex flex-column gap-3">
                            <!-- Summary Only -->
                            <div class="export-option-card" t-on-click="() => this.doExport(false)">
                                <span class="export-option-icon">📊</span>
                                <div>
                                    <div class="export-option-title">Summary Only</div>
                                    <div class="export-option-desc">Export account balances only — one row per account, no transaction breakdown.</div>
                                </div>
                            </div>
                            <!-- With Transaction Details -->
                            <div class="export-option-card" t-on-click="() => this.doExport(true)">
                                <span class="export-option-icon">📋</span>
                                <div>
                                    <div class="export-option-title">With Transaction Details</div>
                                    <div class="export-option-desc">Export full breakdown — includes every journal entry line under each account.</div>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4 text-end">
                            <button class="btn btn-sm btn-outline-secondary" t-on-click="cancelExport">Cancel</button>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>

    <t t-name="dynamic_balance_sheet_report.BalanceSheetRowTemplate" owl="1">
        <tr class="bs-row" t-att-class="props.expandedDetails.has(key) ? 'expanded' : ''" 
            t-on-click="() => props.toggleDetail(key)" style="cursor: pointer;">
            <td class="bs-cell-name">
                <div class="d-flex align-items-center" t-att-style="'padding-left: ' + (level * 20) + 'px'">
                    <i class="oi bs-toggle-icon me-3" 
                       t-att-class="props.expandedDetails.has(key) ? 'oi-chevron-bottom text-primary' : 'oi-chevron-right'"/>
                    <span class="bs-acc-text">
                        <span class="fw-bold text-muted me-2"><t t-esc="acc.code"/></span>
                        <span t-att-class="props.expandedDetails.has(key) ? 'fw-bold' : ''"><t t-esc="acc.name"/></span>
                        <i class="oi oi-more-v ms-2 text-muted" style="font-size: 10px; opacity: 0.2;"/>
                    </span>
                </div>
            </td>
            <td class="bs-cell-amount text-end">
                <span t-att-class="acc.balance &lt; 0 ? 'text-danger' : 'text-dark'" t-att-style="props.expandedDetails.has(key) ? 'font-weight: 700;' : ''">
                    <t t-esc="formatAmount(acc.balance)"/>
                </span>
            </td>
        </tr>
        <!-- Hierarchical Transactions -->
        <t t-if="props.expandedDetails.has(key)">
            <!-- Detail Header -->
            <tr class="bs-detail-header-row bg-light bg-opacity-50">
                <td class="bs-cell-name">
                    <div class="d-flex align-items-center" t-att-style="'padding-left: ' + ((level + 1) * 20) + 'px'">
                        <div class="bs-line-connector me-3" style="opacity: 0;"/>
                        <div class="row w-100 g-0 align-items-center fw-bold text-uppercase" style="font-size: 10px; color: #4b5563; letter-spacing: 0.5px;">
                            <div class="col-2">Date</div>
                            <div class="col-4">Reference</div>
                            <div class="col-3 text-end">Debit</div>
                            <div class="col-3 text-end">Credit</div>
                        </div>
                    </div>
                </td>
                <td class="text-end fw-bold text-uppercase ps-3" style="font-size: 10px; color: #4b5563; padding-right: 16px;">Balance</td>
            </tr>
            <!-- Detail Data -->
            <t t-if="acc.lines and acc.lines.length > 0">
                <t t-foreach="getVisibleLines(acc)" t-as="line" t-key="line.id">
                    <tr class="bs-line-hierarchical">
                        <td class="bs-cell-name">
                            <div class="d-flex align-items-center" t-att-style="'padding-left: ' + ((level + 1) * 20) + 'px'">
                                <div class="bs-line-connector me-3"/>
                                <div class="row w-100 g-0 align-items-center" style="font-size: 11px; color: black;">
                                    <div class="col-2 text-truncate"><t t-esc="formatDate(line.date)"/></div>
                                    <div class="col-4 text-truncate"><t t-esc="line.move_name"/></div>
                                    <div class="col-3 text-end pe-2"><t t-esc="formatAmount(line.debit)"/></div>
                                    <div class="col-3 text-end pe-2"><t t-esc="formatAmount(line.credit)"/></div>
                                </div>
                            </div>
                        </td>
                        <td class="text-end align-middle fw-bold ps-3" style="font-size: 11px; color: black; padding-right: 16px;">
                            <t t-esc="formatAmount(line.balance)"/>
                        </td>
                    </tr>
                </t>
                <!-- Load More row -->
                <t t-if="hasMore(acc)">
                    <tr class="bs-load-more-row">
                        <td colspan="2" t-att-style="'padding-left: ' + ((level + 1) * 20) + 'px'">
                            <button class="btn btn-link btn-sm text-primary py-1 px-2"
                                t-on-click.stop="() => this.loadMore(acc.code, acc.lines.length)">
                                <i class="oi oi-arrow-down me-1" style="font-size: 10px;"/>
                                Load More (<t t-esc="remainingCount(acc)"/> remaining)
                            </button>
                        </td>
                    </tr>
                </t>
            </t>
            <t t-else="">
                <tr>
                    <td colspan="2" t-att-style="'padding-left: ' + ((level + 2) * 20) + 'px'" class="py-2 text-muted small italic">
                        No transactions found.
                    </td>
                </tr>
            </t>
        </t>
    </t>


    <t t-name="dynamic_balance_sheet_report.BalanceSheetComponentTemplate" owl="1">
        <div class="bs-container">
            <style>
                .bs-table { width: 100%; border-collapse: collapse; }
                .bs-header-main { 
                    background: #e5e7eb; 
                    color: #111827; 
                    font-weight: 700; 
                    text-transform: uppercase; 
                    padding: 8px 16px;
                    font-size: 13px;
                }
                .bs-header-sub {
                    font-weight: 700;
                    padding: 12px 16px;
                    border-bottom: 1px solid #f3f4f6;
                    font-size: 14px;
                    cursor: pointer;
                    transition: background 0.2s;
                }
                .bs-header-sub:hover { background: #f9fafb; }
                .bs-row { border-bottom: 1px solid #f3f4f6; transition: background 0.1s; }
                .bs-row:hover { background: #f9fafb; }
                .bs-cell-name { padding: 10px 16px; font-size: 13px; color: #4b5563; }
                .bs-cell-amount { padding: 10px 16px; font-size: 13px; font-weight: 500; }
                .bs-toggle-icon { font-size: 10px; cursor: pointer; color: #9ca3af; }
                .bs-total-row { font-weight: 700; border-top: 1px solid #e5e7eb; background: #fafafa; }
                .bs-detail-container { padding: 10px; background: #fdfdfd; border: 1px solid #f3f4f6; border-radius: 4px; margin: 5px 0 15px 0; }
                .text-danger { color: #dc2626 !important; }
                .bs-line-hierarchical { border-bottom: 1px solid #f9fafb; }
                .bs-line-hierarchical:hover { background: #fdfdfd; }
                .bs-line-connector { 
                    width: 12px; 
                    height: 12px; 
                    border-left: 1px solid #9ca3af; 
                    border-bottom: 1px solid #9ca3af; 
                    margin-top: -6px;
                }
                .bs-load-more-row { border-bottom: 1px solid #f3f4f6; background: #fafafa; }
                .bs-load-more-row:hover { background: #f3f4f6; }
            </style>
            
            <table class="bs-table">
                <tbody>
                    <!-- ASSETS -->
                    <tr><td colspan="2" class="bs-header-main">ASSETS</td></tr>
                    
                    <!-- Current Assets -->
                    <t t-if="props.reportData.assets_current and props.reportData.assets_current.length > 0">
                        <tr class="bs-header-sub" t-on-click="() => props.toggleDetail('section_assets_current')">
                            <td colspan="2" style="padding-left: 24px;">
                                <i class="oi me-2 text-primary" t-att-class="props.expandedDetails.has('section_assets_current') ? 'oi-chevron-bottom' : 'oi-chevron-right'" style="font-size: 10px;"/>
                                Current Assets
                            </td>
                        </tr>
                        <t t-if="props.expandedDetails.has('section_assets_current')">
                            <t t-foreach="props.reportData.assets_current" t-as="acc" t-key="acc.code">
                                <t t-call="dynamic_balance_sheet_report.BalanceSheetRowTemplate">
                                    <t t-set="key" t-value="'asset_current_' + acc.code"/>
                                    <t t-set="level" t-value="2"/>
                                </t>
                            </t>
                        </t>
                        <tr class="bs-total-row">
                            <td class="bs-cell-name" style="padding-left: 44px;">Total Current Assets</td>
                            <td class="bs-cell-amount text-end"><t t-esc="formatAmount(props.reportData.totals.assets_current)"/></td>
                        </tr>
                    </t>

                    <!-- Non-Current Assets -->
                    <t t-if="props.reportData.assets_non_current and props.reportData.assets_non_current.length > 0">
                        <tr class="bs-header-sub" t-on-click="() => props.toggleDetail('section_assets_non_current')">
                            <td colspan="2" style="padding-left: 24px;">
                                <i class="oi me-2 text-primary" t-att-class="props.expandedDetails.has('section_assets_non_current') ? 'oi-chevron-bottom' : 'oi-chevron-right'" style="font-size: 10px;"/>
                                Non-Current Assets
                            </td>
                        </tr>
                        <t t-if="props.expandedDetails.has('section_assets_non_current')">
                            <t t-foreach="props.reportData.assets_non_current" t-as="acc" t-key="acc.code">
                                <t t-call="dynamic_balance_sheet_report.BalanceSheetRowTemplate">
                                    <t t-set="key" t-value="'asset_non_current_' + acc.code"/>
                                    <t t-set="level" t-value="2"/>
                                </t>
                            </t>
                        </t>
                        <tr class="bs-total-row">
                            <td class="bs-cell-name" style="padding-left: 44px;">Total Non-Current Assets</td>
                            <td class="bs-cell-amount text-end"><t t-esc="formatAmount(props.reportData.totals.assets_non_current)"/></td>
                        </tr>
                    </t>

                    <tr class="bs-total-row" style="background: #f3f4f6; font-size: 14px;">
                        <td class="bs-cell-name">TOTAL ASSETS</td>
                        <td class="bs-cell-amount text-end" t-att-class="props.reportData.totals.total_assets &lt; 0 ? 'text-danger' : ''">
                            <t t-esc="formatAmount(props.reportData.totals.total_assets)"/>
                        </td>
                    </tr>

                    <!-- LIABILITIES AND EQUITY -->
                    <tr><td colspan="2" class="bs-header-main" style="margin-top: 20px;">LIABILITIES AND EQUITY</td></tr>
                    
                    <!-- Current Liabilities -->
                    <t t-if="props.reportData.liabilities_current and props.reportData.liabilities_current.length > 0">
                        <tr class="bs-header-sub" t-on-click="() => props.toggleDetail('section_liabilities_current')">
                            <td colspan="2" style="padding-left: 24px;">
                                <i class="oi me-2 text-primary" t-att-class="props.expandedDetails.has('section_liabilities_current') ? 'oi-chevron-bottom' : 'oi-chevron-right'" style="font-size: 10px;"/>
                                Current Liabilities
                            </td>
                        </tr>
                        <t t-if="props.expandedDetails.has('section_liabilities_current')">
                            <t t-foreach="props.reportData.liabilities_current" t-as="acc" t-key="acc.code">
                                <t t-call="dynamic_balance_sheet_report.BalanceSheetRowTemplate">
                                    <t t-set="key" t-value="'liab_current_' + acc.code"/>
                                    <t t-set="level" t-value="2"/>
                                </t>
                            </t>
                        </t>
                        <tr class="bs-total-row">
                            <td class="bs-cell-name" style="padding-left: 44px;">Total Current Liabilities</td>
                            <td class="bs-cell-amount text-end"><t t-esc="formatAmount(props.reportData.totals.liabilities_current)"/></td>
                        </tr>
                    </t>

                    <!-- Equity -->
                    <t t-if="props.reportData.equity and props.reportData.equity.length > 0">
                        <tr class="bs-header-sub" t-on-click="() => props.toggleDetail('section_equity')">
                            <td colspan="2" style="padding-left: 24px;">
                                <i class="oi me-2 text-primary" t-att-class="props.expandedDetails.has('section_equity') ? 'oi-chevron-bottom' : 'oi-chevron-right'" style="font-size: 10px;"/>
                                Equity
                            </td>
                        </tr>
                        <t t-if="props.expandedDetails.has('section_equity')">
                            <t t-foreach="props.reportData.equity" t-as="acc" t-key="acc.code">
                                <t t-call="dynamic_balance_sheet_report.BalanceSheetRowTemplate">
                                    <t t-set="key" t-value="'equity_' + acc.code"/>
                                    <t t-set="level" t-value="2"/>
                                </t>
                            </t>
                        </t>
                        <tr class="bs-total-row">
                            <td class="bs-cell-name" style="padding-left: 44px;">Total Equity</td>
                            <td class="bs-cell-amount text-end"><t t-esc="formatAmount(props.reportData.totals.total_equity)"/></td>
                        </tr>
                    </t>

                    <tr class="bs-total-row" style="background: #f3f4f6; font-size: 14px;">
                        <td class="bs-cell-name">TOTAL LIABILITIES AND EQUITY</td>
                        <td class="bs-cell-amount text-end" t-att-class="props.reportData.totals.total_liabilities_equity &lt; 0 ? 'text-danger' : ''">
                            <t t-esc="formatAmount(props.reportData.totals.total_liabilities_equity)"/>
                        </td>
                    </tr>
                </tbody>
            </table>
            
            <div t-if="props.reportData.totals.total_assets != props.reportData.totals.total_liabilities_equity" 
                 class="p-3 mt-3 border border-warning rounded bg-warning bg-opacity-10 text-warning-emphasis small">
                <strong>Attention:</strong> The Balance Sheet is not balanced. Difference: 
                <t t-esc="formatAmount(Math.abs(props.reportData.totals.total_assets - props.reportData.totals.total_liabilities_equity))"/>
            </div>
        </div>
    </t>
</templates>
